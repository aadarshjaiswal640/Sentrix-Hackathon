# ─── Sentrix SOC — Docker Environment Configuration ──────────────────────────
#
# Edit this file before running `docker compose up -d`.
# All variables have safe defaults for single-machine deployments.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Suricata Interface ────────────────────────────────────────────────────────
# The host network interface Suricata will monitor.
# Run `ip link show` (Linux) or `ifconfig` (macOS) to find your interface name.
#
# Common values:
#   eth0     — most Linux VMs and servers
#   enp0s3   — VirtualBox Linux guests
#   ens3     — KVM/QEMU Linux guests
#   en0      — macOS primary interface
#
# WARNING: Setting the wrong interface means Suricata sees no traffic.
SURICATA_IFACE=eth0

# ── Server LAN IP ─────────────────────────────────────────────────────────────
# The IP address of this machine on the local network.
# Used as the Elasticsearch URL returned to remote agents.
#
# Single-machine mode (agent and server on same host):
#   Leave as 127.0.0.1
#
# Multi-machine mode (agents on separate hosts):
#   Set to this server's LAN IP, e.g. 192.168.1.10
#   Agents must be able to reach this IP on port 9200 (Elasticsearch)
#   and port 8000 (session-manager).
SENTRIX_SERVER_IP=127.0.0.1
